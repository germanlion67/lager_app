# ============================================================
# Lager App — Production Environment Variables
# 
# WICHTIG: Diese Datei enthält sensible Daten!
# - NIE ins Git committen!
# - Sichere Passwörter verwenden!
# - In Production: Secrets Management nutzen
# ============================================================

# ============================================================
# PocketBase Admin Account (Erstinitialisierung)
# Wird beim ersten Start automatisch erstellt
# ============================================================
PB_ADMIN_EMAIL=admin@your-domain.com
PB_ADMIN_PASSWORD=CHANGE_THIS_SECURE_PASSWORD_123!

# ============================================================
# Application URLs
# WICHTIG: Diese URL muss vom Browser erreichbar sein!
# ============================================================
# PocketBase API URL (öffentlich erreichbar)
# Beispiele:
#   - https://api.example.com
#   - https://example.com/api
POCKETBASE_URL=https://api.your-domain.com

# ============================================================
# Internal Ports (Docker network only)
# Diese Ports werden NICHT nach außen exponiert
# ============================================================
PB_PORT=8080
WEB_PORT=8081

# ============================================================
# Optional: CORS Configuration
# ============================================================
# Komma-getrennte Liste erlaubter Origins
# Für single domain: https://your-domain.com
# Für multiple: https://your-domain.com,https://app.your-domain.com
# CORS_ALLOWED_ORIGINS=https://your-domain.com
