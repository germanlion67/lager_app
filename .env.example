# ============================================================
# Lager App — Umgebungsvariablen
# Vorlage — Kopieren und anpassen:
#   Dev/Test:   cp .env.example .env
#   Produktion: cp .env.production.example .env.production
# ============================================================

# Port für Flutter Web App (Caddy)
WEB_PORT=8081

# Port für PocketBase (API + Admin UI)
# Admin UI: http://localhost:8080/_/
# API:      http://localhost:8080/api/
PB_PORT=8080

# Vom Browser erreichbare PocketBase URL
# WICHTIG: Muss vom Browser des Nutzers erreichbar sein — nicht die
#          interne Docker-Adresse! Der Flutter Web Build läuft im
#          Browser, nicht im Container.
#
# Dev/Test:   http://localhost:8080  (funktioniert weil Port gemappt ist)
# Produktion: https://api.deine-domain.de
POCKETBASE_URL=http://localhost:8080

# PocketBase Admin-Account (wird beim ersten Start automatisch erstellt)
# ⚠️ WICHTIG: Passwort nach erstem Login ändern!
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=changeme123

# Optional: überschreibt bei jedem Start (wenn 1) den Superuser via upsert
PB_FORCE_SUPERUSER_UPSERT=0

# Dev-Modus: 1 = offene Regeln (kein Login nötig), 0 = Produktions-Regeln
# In Produktion auf 0 setzen!
PB_DEV_MODE=1

# CORS-Konfiguration: Erlaubte Origins (komma-getrennt, keine Leerzeichen!)
# Dev/Test: * erlaubt alle Origins (praktisch für lokale Entwicklung)
# Produktion: Spezifische Domain(s) angeben
# Beispiele:
#   CORS_ALLOWED_ORIGINS=https://app.deine-domain.de
#   CORS_ALLOWED_ORIGINS=https://app.deine-domain.de,https://admin.deine-domain.de
CORS_ALLOWED_ORIGINS=*

# =============================================================================
# Backup-Konfiguration
# =============================================================================

# Backup aktivieren/deaktivieren
BACKUP_ENABLED=true

# Cron-Schedule (Standard: täglich um 3:00 Uhr)
# Format: Minute Stunde Tag Monat Wochentag
BACKUP_CRON=0 3 * * *

# Anzahl Tage, die Backups aufbewahrt werden
BACKUP_KEEP_DAYS=7

# Zeitzone für Cron und Zeitstempel
TZ=Europe/Berlin

# =============================================================================
# Backup-Benachrichtigung (optional)
# =============================================================================

# Benachrichtigungstyp: none | email | webhook
BACKUP_NOTIFY=none

# ── E-Mail (SMTP) ──
# Nur relevant wenn BACKUP_NOTIFY=email
BACKUP_SMTP_HOST=smtp.example.com
BACKUP_SMTP_PORT=587
BACKUP_SMTP_USER=backup@example.com
BACKUP_SMTP_PASS=
BACKUP_SMTP_FROM=backup@example.com
BACKUP_SMTP_TO=admin@example.com

# ── Webhook ──
# Nur relevant wenn BACKUP_NOTIFY=webhook
# Kompatibel mit Slack, Discord, Gotify, Ntfy, etc.
BACKUP_WEBHOOK_URL=