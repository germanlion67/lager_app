# lager_app/.gitignore

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# Flutter/Dart/Pub related (angepasst für /app Unterordner)
app/.dart_tool/
app/.flutter-plugins-dependencies
app/.pub-cache/
app/.pub/
app/build/
app/coverage/
**/doc/api/
**/ios/Flutter/.last_build_id

# Symbolication / Obfuscation
app.*.symbols
app.*.map.json

# Android Studio build artifacts
app/android/app/debug
app/android/app/profile
app/android/app/release

# --- NEU: PocketBase / Docker Backend ---
# Ignoriere die lokale Datenbank und Konfigurationen
server/pb_data/
# Falls du Hooks oder Migrationen nutzt, die nicht ins Repo sollen:
# server/pb_migrations/

# Eigene
infos._js
prompt.txt
.dart_tool/

# Generierte Dateien und temporäre Ausgaben aus dem Root-Verzeichnis oder global
# Diese Dateien sollten nicht versioniert werden, da sie generiert werden können
analyze_output.txt
.flutter-plugins-dependencies
.metadata

# Sensible Umgebungsvariablen
# Diese Datei enthält oft sensible Daten und sollte niemals eingecheckt werden.
# Stattdessen sollte eine .env.example oder .env.dist ins Repo, die die Struktur zeigt.
.env
.env.local
.env.production

# Backup-Dateien
# Backup-Dateien sind generierte Artefakte und sollten nicht versioniert werden.
server/*.tar.gz

# Keystore-Dateien
**/*.jks
**/*.keystore
**/key.propertiesapp/assets/images/app_logo.png.bak
