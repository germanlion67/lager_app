# lager_app/app/.gitignore

# Flutter Build-Artefakte
build/
.dart_tool/
.flutter-plugins-dependencies
.flutter-plugins

# Android Auto-generated
android/.gradle/
android/local.properties
android/app/src/main/java/io/flutter/plugins/GeneratedPluginRegistrant.java

# iOS Auto-generated
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh
ios/Flutter/ephemeral/
ios/Runner/GeneratedPluginRegistrant.h
ios/Runner/GeneratedPluginRegistrant.m

# Linux/macOS/Windows Ephemeral
linux/flutter/ephemeral/
macos/Flutter/ephemeral/
windows/flutter/ephemeral/.flutter-plugins-dependencies

# Generierte Dateien und temporäre Ausgaben aus dem app/ Verzeichnis
# Diese Dateien sollten nicht versioniert werden, da sie generiert werden können
analyze_output.txt
.metadata
info._js # Wenn es sich um eine temporäre oder lokale Notiz handelt
prompt.txt # Wenn es sich um eine temporäre oder lokale Notiz handelt
tool/Erklärung.txt # Wenn es sich um eine temporäre oder lokale Notiz handelt